# Environment Configuration

# Google Maps API Key (LIVE DATA SUPPORT)
# To enable live data from Google Maps:
# 1. Go to https://console.cloud.google.com/
# 2. Create new project or select existing
# 3. Enable these APIs in Google Cloud Console:
#    - Maps Static API
#    - Places API  
#    - Distance Matrix API
#    - Geocoding API
# 4. Create API Key under Credentials
# 5. Set the key below to enable live data instead of mock data
GOOGLE_MAPS_API_KEY=your_api_key_here

# OpenAI API Key (for LLM-based reasoning and intelligence)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Logging Configuration
LOG_LEVEL=INFO

# LLM Configuration
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Optional: API Rate Limiting
API_RATE_LIMIT=100  # requests per minute

# Memory and Personalization
MEMORY_FILE=user_memory.json
ENABLE_LEARNING=true
